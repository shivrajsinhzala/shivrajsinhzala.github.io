---
import Layout from '../layouts/Layout.astro';
import { blogPosts } from '../data/blog-posts';
---

<Layout title="Site Directory & HTML Sitemap | Shivrajsinh Zala" description="Browse the site directory and HTML sitemap for Shivrajsinh Zala's portfolio, listing core pages, resume, image gallery, and development blogs.">
    <Fragment slot="head">
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://shivrajsinh.in/directory" />
        <meta property="og:title" content="Site Directory — Shivrajsinh Zala" />
        <meta property="og:description" content="HTML sitemap and directory for Shivrajsinh Zala's portfolio, blog, gallery, and resources." />
        <meta property="og:image" content="https://shivrajsinh.in/assets/images/og-image.png" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="Site Directory — Shivrajsinh Zala" />
        <meta name="twitter:description" content="HTML sitemap and directory for Shivrajsinh Zala's portfolio, blog, gallery, and resources." />
        <meta name="twitter:image" content="https://shivrajsinh.in/assets/images/og-image.png" />
        <script type="application/ld+json" is:inline>
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "https://shivrajsinh.in/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Directory",
              "item": "https://shivrajsinh.in/directory"
            }
          ]
        }
        </script>
        <script type="application/ld+json" is:inline>
        {
          "@context": "https://schema.org",
          "@graph": [
            {
              "@type": "WebPage",
              "@id": "https://shivrajsinh.in/directory/#webpage",
              "url": "https://shivrajsinh.in/directory",
              "name": "Site Directory & Social Index — Shivrajsinh Zala",
              "isPartOf": {
                "@type": "WebSite",
                "@id": "https://shivrajsinh.in/#website",
                "name": "Shivrajsinh Zala Portfolio",
                "url": "https://shivrajsinh.in/"
              },
              "about": {
                "@type": "Person",
                "@id": "https://shivrajsinh.in/#person",
                "name": "Shivrajsinh Zala",
                "sameAs": [
                  "https://www.linkedin.com/in/shivrajsinh-zala/",
                  "https://www.instagram.com/shivrajsinh.sh",
                  "https://github.com/shivrajsinhzala",
                  "https://t.me/ShivrajsinhZala"
                ]
              }
            }
          ]
        }
        </script>
    </Fragment>

    <main class="relative z-10 pt-24 pb-20 px-4 max-w-4xl mx-auto">
        
        <header class="mb-12 border-2 border-black bg-white p-6 md:p-8 shadow-[8px_8px_0_0_#000]">
            <h1 class="text-4xl md:text-5xl font-bold tracking-tighter mb-4 uppercase text-black">
                Site Directory
            </h1>
            <p class="font-mono text-gray-700">
                HTML Sitemap / Index
            </p>
        </header>

        <section class="mb-12">
            <h2 class="text-2xl font-bold font-mono mb-4 uppercase border-b-2 border-black pb-2 inline-block">Core Pages</h2>
            <div class="grid grid-cols-1 gap-4 mt-4">
                <a href="/" class="block bg-white border-2 border-black p-4 hover:bg-brutal-yellow transition-colors font-bold text-lg flex items-center justify-between">
                    <span>Home Page</span>
                    <span class="font-mono text-sm border border-black px-2 py-1 bg-black text-white">/</span>
                </a>
                <a href="/gallery" class="block bg-white border-2 border-black p-4 hover:bg-brutal-yellow transition-colors font-bold text-lg flex items-center justify-between">
                    <span>Press Kit & Image Gallery</span>
                    <span class="font-mono text-sm border border-black px-2 py-1 bg-black text-white">/gallery</span>
                </a>
                <a href="/blog" class="block bg-white border-2 border-black p-4 hover:bg-brutal-yellow transition-colors font-bold text-lg flex items-center justify-between">
                    <span>Blog — Articles & Guides</span>
                    <span class="font-mono text-sm border border-black px-2 py-1 bg-black text-white">/blog</span>
                </a>
                <a href="/contact" class="block bg-white border-2 border-black p-4 hover:bg-brutal-yellow transition-colors font-bold text-lg flex items-center justify-between">
                    <span>Contact Us — Direct Inquiry Form</span>
                    <span class="font-mono text-sm border border-black px-2 py-1 bg-black text-white">/contact</span>
                </a>
                <a href="/resume" class="block bg-white border-2 border-black p-4 hover:bg-brutal-yellow transition-colors font-bold text-lg flex items-center justify-between">
                    <span>Online Resume & Print Sheet</span>
                    <span class="font-mono text-sm border border-black px-2 py-1 bg-black text-white">/resume</span>
                </a>
            </div>
        </section>
        
        <section class="mb-12">
            <h2 class="text-2xl font-bold font-mono mb-4 uppercase border-b-2 border-black pb-2 inline-block">SEO Blogs & Articles</h2>
            <div class="grid grid-cols-1 gap-4 mt-4">
                {blogPosts.map((post) => (
                    <a href={`/blog/${post.slug}`} class="block bg-white border-2 border-black p-4 hover:bg-[#00FF88] transition-colors font-bold text-lg flex flex-col md:flex-row md:items-center justify-between gap-2">
                        <span>{post.title}</span>
                        <span class="font-mono text-xs md:text-sm text-gray-500 break-all">/blog/{post.slug}</span>
                    </a>
                ))}
            </div>
        </section>

        <section class="mb-12">
            <h2 class="text-2xl font-bold font-mono mb-4 uppercase border-b-2 border-black pb-2 inline-block">Official Social Profiles</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
                <a href="https://www.linkedin.com/in/shivrajsinh-zala/" target="_blank" rel="me noopener noreferrer" class="block bg-white border-2 border-black p-4 hover:bg-brutal-cyan transition-colors font-bold text-lg flex items-center justify-between">
                    <span>Shivrajsinh Zala on LinkedIn</span>
                    <span class="font-mono text-xs border border-black px-2 py-1 bg-black text-white">PROFESSIONAL</span>
                </a>
                <a href="https://www.instagram.com/shivrajsinh.sh" target="_blank" rel="me noopener noreferrer" class="block bg-white border-2 border-black p-4 hover:bg-brutal-pink transition-colors font-bold text-lg flex items-center justify-between">
                    <span>Shivrajsinh Zala on Instagram</span>
                    <span class="font-mono text-xs border border-black px-2 py-1 bg-black text-white">CREATIVE</span>
                </a>
                <a href="https://github.com/shivrajsinhzala" target="_blank" rel="me noopener noreferrer" class="block bg-white border-2 border-black p-4 hover:bg-[#00FF88] transition-colors font-bold text-lg flex items-center justify-between">
                    <span>Shivrajsinh Zala on GitHub</span>
                    <span class="font-mono text-xs border border-black px-2 py-1 bg-black text-white">CODE</span>
                </a>
                <a href="https://t.me/ShivrajsinhZala" target="_blank" rel="me noopener noreferrer" class="block bg-white border-2 border-black p-4 hover:bg-[#00AAFF] transition-colors font-bold text-lg flex items-center justify-between">
                    <span>Shivrajsinh Zala on Telegram</span>
                    <span class="font-mono text-xs border border-black px-2 py-1 bg-black text-white">CHAT</span>
                </a>
            </div>
        </section>
        
    </main>



    
</Layout>
