---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Directory - Shivrajsinh Zala" description="Site directory and HTML sitemap for Shivrajsinh Zala.">
    <Fragment slot="head">
        <meta name="robots" content="index, follow">
<link rel="icon" type="image/png" sizes="48x48" href="favicon.png">
<link rel="shortcut icon" href="favicon.png">
<link rel="apple-touch-icon" href="favicon.png">
    </Fragment>

    <main class="relative z-10 pt-24 pb-20 px-4 max-w-4xl mx-auto">
        
        <header class="mb-12 border-2 border-black bg-white p-6 md:p-8 shadow-[8px_8px_0_0_#000]">
            <h1 class="text-4xl md:text-5xl font-bold tracking-tighter mb-4 uppercase text-black">
                Site Directory
            </h1>
            <p class="font-mono text-gray-700">
                HTML Sitemap / Index
            </p>
        </header>

        <section class="mb-12">
            <h2 class="text-2xl font-bold font-mono mb-4 uppercase border-b-2 border-black pb-2 inline-block">Core Pages</h2>
            <div class="grid grid-cols-1 gap-4 mt-4">
                <a href="/" class="block bg-white border-2 border-black p-4 hover:bg-brutal-yellow transition-colors font-bold text-lg flex items-center justify-between">
                    <span>Home Page</span>
                    <span class="font-mono text-sm border border-black px-2 py-1 bg-black text-white">/</span>
                </a>
                <a href="/gallery.html" class="block bg-white border-2 border-black p-4 hover:bg-brutal-yellow transition-colors font-bold text-lg flex items-center justify-between">
                    <span>Press Kit & Image Gallery</span>
                    <span class="font-mono text-sm border border-black px-2 py-1 bg-black text-white">/gallery.html</span>
                </a>
            </div>
        </section>
        
        <section class="mb-12">
            <h2 class="text-2xl font-bold font-mono mb-4 uppercase border-b-2 border-black pb-2 inline-block">SEO Blogs & Articles</h2>
            <div class="grid grid-cols-1 gap-4 mt-4">
                <a href="/blog/about-shivrajsinh-zala-frontend-developer.html" class="block bg-white border-2 border-black p-4 hover:bg-[#00FF88] transition-colors font-bold text-lg flex flex-col md:flex-row md:items-center justify-between gap-2">
                    <span>About Shivrajsinh Zala - Frontend Developer</span>
                    <span class="font-mono text-xs md:text-sm text-gray-500 break-all">/blog/about-shivrajsinh-zala-frontend-developer.html</span>
                </a>
                
                <a href="/blog/interview-shivrajsinh-zala-rajkot-web-design.html" class="block bg-white border-2 border-black p-4 hover:bg-[#00FF88] transition-colors font-bold text-lg flex flex-col md:flex-row md:items-center justify-between gap-2">
                    <span>Interview with Shivrajsinh Zala</span>
                    <span class="font-mono text-xs md:text-sm text-gray-500 break-all">/blog/interview-shivrajsinh-zala-rajkot-web-design.html</span>
                </a>
                
                <a href="/blog/hire-shivrajsinh-zala-frontend-developer-rajkot.html" class="block bg-white border-2 border-black p-4 hover:bg-[#00FF88] transition-colors font-bold text-lg flex flex-col md:flex-row md:items-center justify-between gap-2">
                    <span>Why You Should Hire Shivrajsinh Zala</span>
                    <span class="font-mono text-xs md:text-sm text-gray-500 break-all">/blog/hire-shivrajsinh-zala-frontend-developer-rajkot.html</span>
                </a>
                
                <a href="/blog/shivrajsinh-zala-tech-stack-react-gsap-tailwind.html" class="block bg-white border-2 border-black p-4 hover:bg-[#00FF88] transition-colors font-bold text-lg flex flex-col md:flex-row md:items-center justify-between gap-2">
                    <span>Shivrajsinh Zala's Tech Stack</span>
                    <span class="font-mono text-xs md:text-sm text-gray-500 break-all">/blog/shivrajsinh-zala-tech-stack-react-gsap-tailwind.html</span>
                </a>
                
                <a href="/blog/shivrajsinh-zala-developer-journey-rajkot-gujarat.html" class="block bg-white border-2 border-black p-4 hover:bg-[#00FF88] transition-colors font-bold text-lg flex flex-col md:flex-row md:items-center justify-between gap-2">
                    <span>From Rajkot to the World — A Developer's Journey</span>
                    <span class="font-mono text-xs md:text-sm text-gray-500 break-all">/blog/shivrajsinh-zala-developer-journey-rajkot-gujarat.html</span>
                </a>
                
                <a href="/blog/shivrajsinh-zala-ecommerce-developer-shopify-webflow.html" class="block bg-white border-2 border-black p-4 hover:bg-[#00FF88] transition-colors font-bold text-lg flex flex-col md:flex-row md:items-center justify-between gap-2">
                    <span>The E-commerce Developer Who Knows Shopify & Webflow</span>
                    <span class="font-mono text-xs md:text-sm text-gray-500 break-all">/blog/shivrajsinh-zala-ecommerce-developer-shopify-webflow.html</span>
                </a>
                
                <a href="/blog/shivrajsinh-zala-wordpress-developer-custom-themes.html" class="block bg-white border-2 border-black p-4 hover:bg-[#00FF88] transition-colors font-bold text-lg flex flex-col md:flex-row md:items-center justify-between gap-2">
                    <span>WordPress Custom Development Expert</span>
                    <span class="font-mono text-xs md:text-sm text-gray-500 break-all">/blog/shivrajsinh-zala-wordpress-developer-custom-themes.html</span>
                </a>
                
                <a href="/blog/brutalist-web-design-frontend.html" class="block bg-white border-2 border-black p-4 hover:bg-[#00FF88] transition-colors font-bold text-lg flex flex-col md:flex-row md:items-center justify-between gap-2">
                    <span>Brutalist Web Design — A Frontend Perspective</span>
                    <span class="font-mono text-xs md:text-sm text-gray-500 break-all">/blog/brutalist-web-design-frontend.html</span>
                </a>
                
                <a href="/blog/custom-wordpress-development-2026.html" class="block bg-white border-2 border-black p-4 hover:bg-[#00FF88] transition-colors font-bold text-lg flex flex-col md:flex-row md:items-center justify-between gap-2">
                    <span>Custom WordPress Development in 2026</span>
                    <span class="font-mono text-xs md:text-sm text-gray-500 break-all">/blog/custom-wordpress-development-2026.html</span>
                </a>
                
                <a href="/blog/shopify-vs-webflow-ecommerce.html" class="block bg-white border-2 border-black p-4 hover:bg-[#00FF88] transition-colors font-bold text-lg flex flex-col md:flex-row md:items-center justify-between gap-2">
                    <span>Shopify vs Webflow for E-commerce</span>
                    <span class="font-mono text-xs md:text-sm text-gray-500 break-all">/blog/shopify-vs-webflow-ecommerce.html</span>
                </a>
            </div>
        </section>
        
    </main>

    <footer class="bg-black text-white py-8 border-t-2 border-brutal-cyan mt-12">
        <div class="max-w-4xl mx-auto px-4 text-center font-mono text-sm">
            © 2026 SHIVRAJSINH ZALA. ALL RIGHTS RESERVED.
        </div>
    </footer>

    
</Layout>
