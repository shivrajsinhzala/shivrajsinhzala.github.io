---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Resume | Shivrajsinh Zala | Frontend Developer" description="Professional resume and qualifications of Shivrajsinh Zala, Frontend Developer specializing in React, custom WordPress theme design, Squarespace, and GSAP web animations.">
    <Fragment slot="head">
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://shivrajsinh.in/resume" />
        <meta property="og:title" content="Shivrajsinh Zala — Resume / CV" />
        <meta property="og:description" content="Professional qualifications, experience, and development stack of Shivrajsinh Zala, Frontend Developer in Rajkot, Gujarat." />
        <meta property="og:image" content="https://shivrajsinh.in/assets/images/og-image.png" />
        <meta name="twitter:card" content="summary_large_image" />
        <script type="application/ld+json" is:inline>
        {
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          "itemListElement": [
            {
              "@type": "ListItem",
              "position": 1,
              "name": "Home",
              "item": "https://shivrajsinh.in/"
            },
            {
              "@type": "ListItem",
              "position": 2,
              "name": "Resume",
              "item": "https://shivrajsinh.in/resume"
            }
          ]
        }
        </script>
    </Fragment>

    <main class="relative z-10 pt-28 pb-24 px-4 max-w-4xl mx-auto print:pt-0 print:pb-0 print:px-0 print:max-w-full">
        <!-- Print Header & Controls (hidden in print) -->
        <div class="mb-8 flex flex-col sm:flex-row justify-between items-center gap-4 bg-white brutal-border p-4 shadow-[4px_4px_0_0_#000] print:hidden">
            <span class="font-mono text-xs font-bold text-gray-700 flex items-center gap-2">
                <i data-lucide="info" class="w-4 h-4 text-brutal-pink"></i>
                This page is optimized to print an ATS-friendly, professional PDF resume.
            </span>
            <button 
                id="print-btn"
                class="w-full sm:w-auto brutal-border bg-brutal-yellow text-black hover:bg-black hover:text-white px-5 py-2 font-mono font-bold text-xs md:text-sm tracking-wider cursor-pointer shadow-[3px_3px_0_0_#000] hover:shadow-none hover:translate-x-[3px] hover:translate-y-[3px] active:translate-y-[3px] transition-all flex items-center justify-center gap-2"
            >
                <i data-lucide="printer" class="w-4 h-4"></i>
                PRINT / SAVE PDF
            </button>
        </div>

        <!-- ========================================== -->
        <!-- SCREEN-ONLY INTERACTIVE BRUTALIST RESUME -->
        <!-- ========================================== -->
        <article class="bg-white brutal-border p-6 md:p-10 shadow-[12px_12px_0_0_#000] print:hidden">
            <!-- Header Block -->
            <header class="border-b-4 border-black pb-8 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
                <div>
                    <h1 class="text-4xl md:text-5xl font-black tracking-tighter uppercase text-black">
                        Shivrajsinh Zala
                    </h1>
                    <p class="font-mono text-base md:text-lg text-brutal-pink font-bold mt-1 uppercase">
                        Frontend Developer & WordPress Engineer
                    </p>
                    <p class="font-mono text-xs text-gray-500 mt-2">
                        Rajkot, Gujarat, India · hello@shivrajsinh.in
                    </p>
                </div>
                
                <!-- Quick social / metadata -->
                <div class="font-mono text-xs space-y-1 text-left w-full md:w-auto border-t-2 border-black md:border-t-0 pt-4 md:pt-0">
                    <div class="flex items-center gap-2">
                        <span class="font-bold w-16 text-gray-400">GITHUB:</span>
                        <a href="https://github.com/shivrajsinhzala" target="_blank" class="hover:underline font-bold">github.com/shivrajsinhzala</a>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="font-bold w-16 text-gray-400">LINKEDIN:</span>
                        <a href="https://www.linkedin.com/in/shivrajsinh-zala/" target="_blank" class="hover:underline font-bold">linkedin.com/in/shivrajsinh-zala</a>
                    </div>
                    <div class="flex items-center gap-2">
                        <span class="font-bold w-16 text-gray-400">TELEGRAM:</span>
                        <a href="https://t.me/ShivrajsinhZala" target="_blank" class="hover:underline font-bold">t.me/ShivrajsinhZala</a>
                    </div>
                </div>
            </header>

            <!-- Summary / Objective -->
            <section class="py-8 border-b-2 border-black">
                <h2 class="font-bold font-mono text-xs uppercase tracking-widest text-gray-400 mb-3">01 // PROFILE</h2>
                <p class="font-mono text-sm leading-relaxed text-gray-800">
                    Highly motivated and results-oriented Frontend Developer and MCA graduate with 2+ years of hands-on experience. 
                    Specialized in custom WordPress theme engineering, responsive web application development with React and Tailwind CSS, 
                    and creating high-impact scrolling interactions utilizing GSAP and ScrollTrigger. Strong track record of building and managing 30+ client websites with excellent client satisfaction.
                </p>
            </section>

            <!-- Grid Split for Experience and Education / Skills -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pt-8">
                <!-- Column 1 & 2: Experience -->
                <div class="md:col-span-2 space-y-8">
                    <section>
                        <h2 class="font-bold font-mono text-xs uppercase tracking-widest text-gray-400 mb-5">02 // WORK EXPERIENCE</h2>
                        
                        <div class="space-y-6">
                            <!-- Job 1 -->
                            <div class="brutal-border p-5 bg-brutal-gray/30 shadow-[4px_4px_0_0_#000]">
                                <div class="flex justify-between items-start flex-wrap gap-2 mb-2">
                                    <div>
                                        <h3 class="text-lg font-black font-mono">Frontend Developer</h3>
                                        <h4 class="text-sm font-bold text-gray-700 font-mono">Just Digital Gurus</h4>
                                    </div>
                                    <span class="font-mono text-[10px] bg-brutal-yellow brutal-border px-2 py-0.5 font-bold">
                                        FEB 2025 — PRESENT
                                    </span>
                                </div>
                                <p class="font-mono text-xs text-gray-500 mb-4">Rajkot, Gujarat</p>
                                <ul class="space-y-2 font-mono text-xs text-gray-800 list-disc list-inside">
                                    <li>Develop and maintain 30+ client websites, ensuring fast loading speeds and high SEO ranks.</li>
                                    <li>Custom WordPress theme architecture, code optimization, and custom plugins management.</li>
                                    <li>Implement high-fidelity responsive layout designs from Sketch/Figma files in Squarespace and Webflow.</li>
                                    <li>Design sophisticated UI animations and scroll-driven page elements using GSAP & ScrollTrigger.</li>
                                    <li>Optimize developer workflows using modern web systems and AI-assisted compilation.</li>
                                </ul>
                            </div>
                        </div>
                    </section>

                    <section>
                        <h2 class="font-bold font-mono text-xs uppercase tracking-widest text-gray-400 mb-5">03 // EDUCATION</h2>
                        
                        <div class="space-y-4">
                            <!-- MCA -->
                            <div class="flex gap-4 items-start border-l-4 border-brutal-pink pl-4 py-1">
                                <div class="flex-1 font-mono">
                                    <h3 class="text-sm font-black">Master of Computer Applications (MCA)</h3>
                                    <p class="text-xs text-gray-600">B H Gardi College of Engineering & Technology, Rajkot</p>
                                    <p class="text-[10px] text-gray-400">Gujarat Technological University (GTU)</p>
                                </div>
                                <span class="font-mono text-xs text-gray-500 font-bold whitespace-nowrap">2023 — 2025</span>
                            </div>

                            <!-- BCA -->
                            <div class="flex gap-4 items-start border-l-4 border-brutal-cyan pl-4 py-1">
                                <div class="flex-1 font-mono">
                                    <h3 class="text-sm font-black">Bachelor of Computer Applications (BCA)</h3>
                                    <p class="text-xs text-gray-600">OMVVIM College, Morbi</p>
                                    <p class="text-[10px] text-gray-400">Saurashtra University</p>
                                </div>
                                <span class="font-mono text-xs text-gray-500 font-bold whitespace-nowrap">2020 — 2023</span>
                            </div>
                        </div>
                    </section>
                </div>

                <!-- Column 3: Skills & Stack -->
                <div class="space-y-8 md:col-span-1 border-t-2 border-black md:border-t-0 md:border-l-2 md:pl-8 pt-8 md:pt-0">
                    <section>
                        <h2 class="font-bold font-mono text-xs uppercase tracking-widest text-gray-400 mb-5">04 // CORE STACK</h2>
                        
                        <div class="space-y-4 font-mono">
                            <!-- Skill 1 -->
                            <div class="space-y-1">
                                <div class="flex justify-between text-xs font-bold">
                                    <span>WordPress / Custom Themes</span>
                                    <span>95%</span>
                                </div>
                                <div class="w-full bg-gray-200 brutal-border h-3 overflow-hidden">
                                    <div class="bg-brutal-black h-full" style="width: 95%;"></div>
                                </div>
                            </div>

                            <!-- Skill 2 -->
                            <div class="space-y-1">
                                <div class="flex justify-between text-xs font-bold">
                                    <span>React.js / GSAP Animations</span>
                                    <span>90%</span>
                                </div>
                                <div class="w-full bg-gray-200 brutal-border h-3 overflow-hidden">
                                    <div class="bg-brutal-black h-full" style="width: 90%;"></div>
                                </div>
                            </div>

                            <!-- Skill 3 -->
                            <div class="space-y-1">
                                <div class="flex justify-between text-xs font-bold">
                                    <span>Shopify / Webflow Store</span>
                                    <span>85%</span>
                                </div>
                                <div class="w-full bg-gray-200 brutal-border h-3 overflow-hidden">
                                    <div class="bg-brutal-black h-full" style="width: 85%;"></div>
                                </div>
                            </div>

                            <!-- Skill 4 -->
                            <div class="space-y-1">
                                <div class="flex justify-between text-xs font-bold">
                                    <span>HTML5 / CSS3 / Tailwind</span>
                                    <span>95%</span>
                                </div>
                                <div class="w-full bg-gray-200 brutal-border h-3 overflow-hidden">
                                    <div class="bg-brutal-black h-full" style="width: 95%;"></div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt-4">
                        <h2 class="font-bold font-mono text-xs uppercase tracking-widest text-gray-400 mb-3">05 // TECHNICAL</h2>
                        <div class="flex flex-wrap gap-2 font-mono text-[10px]">
                            <span class="border border-black bg-brutal-yellow/20 px-2 py-0.5">Git / Version Control</span>
                            <span class="border border-black bg-brutal-cyan/20 px-2 py-0.5">Squarespace Theme</span>
                            <span class="border border-black bg-brutal-pink/20 px-2 py-0.5">Figma Integration</span>
                            <span class="border border-black bg-gray-100 px-2 py-0.5">REST API / Fetch</span>
                            <span class="border border-black bg-gray-100 px-2 py-0.5">Vite / Bundlers</span>
                            <span class="border border-black bg-gray-100 px-2 py-0.5">SEO Auditing</span>
                        </div>
                    </section>
                </div>
            </div>
        </article>

        <!-- ========================================== -->
        <!-- PRINT-ONLY ATS-FRIENDLY DOCUMENT RESUME   -->
        <!-- ========================================== -->
        <div class="hidden print:block text-black bg-white max-w-[8.5in] mx-auto antialiased">
            <!-- Header Block -->
            <header class="text-center mb-6 border-b border-gray-300 pb-4">
                <h1 class="text-2xl font-bold uppercase tracking-tight text-black mb-1" style="font-family: Arial, sans-serif;">
                    Shivrajsinh Zala
                </h1>
                <p class="text-xs font-bold text-gray-700 uppercase tracking-wide mb-2" style="font-family: Arial, sans-serif;">
                    Frontend Developer & WordPress Engineer
                </p>
                <div class="text-[10px] text-gray-600 leading-normal" style="font-family: Arial, sans-serif;">
                    Rajkot, Gujarat, India &nbsp;|&nbsp; 
                    <a href="mailto:hello@shivrajsinh.in" class="text-black no-underline">hello@shivrajsinh.in</a> &nbsp;|&nbsp; 
                    <a href="https://shivrajsinh.in" class="text-black no-underline">https://shivrajsinh.in</a>
                    <br />
                    GitHub: <a href="https://github.com/shivrajsinhzala" class="text-black no-underline">github.com/shivrajsinhzala</a> &nbsp;|&nbsp; 
                    LinkedIn: <a href="https://www.linkedin.com/in/shivrajsinh-zala/" class="text-black no-underline">linkedin.com/in/shivrajsinh-zala</a> &nbsp;|&nbsp; 
                    Telegram: <a href="https://t.me/ShivrajsinhZala" class="text-black no-underline">t.me/ShivrajsinhZala</a>
                </div>
            </header>

            <!-- Summary -->
            <section class="mb-5">
                <h2 class="text-xs font-bold uppercase border-b border-black pb-0.5 mb-2 tracking-wide" style="font-family: Arial, sans-serif;">
                    Professional Summary
                </h2>
                <p class="text-[11px] leading-relaxed text-gray-800" style="font-family: Arial, sans-serif;">
                    Highly motivated and results-oriented Frontend Developer and MCA graduate with 2+ years of hands-on experience. 
                    Specialized in custom WordPress theme engineering, responsive web application development with React and Tailwind CSS, 
                    and creating high-impact scrolling interactions utilizing GSAP and ScrollTrigger. Strong track record of building and managing 30+ client websites with excellent client satisfaction.
                </p>
            </section>

            <!-- Work Experience -->
            <section class="mb-5">
                <h2 class="text-xs font-bold uppercase border-b border-black pb-0.5 mb-2 tracking-wide" style="font-family: Arial, sans-serif;">
                    Work Experience
                </h2>
                <div class="space-y-4">
                    <div>
                        <div class="flex justify-between items-baseline font-bold text-[11px]" style="font-family: Arial, sans-serif;">
                            <span>FRONTEND DEVELOPER &nbsp;|&nbsp; Just Digital Gurus</span>
                            <span class="font-normal text-[10px]">FEB 2025 — PRESENT</span>
                        </div>
                        <div class="text-[10px] text-gray-600 italic mb-1" style="font-family: Arial, sans-serif;">Rajkot, Gujarat, India</div>
                        <ul class="list-disc list-outside pl-4 text-[10.5px] space-y-1 text-gray-800" style="font-family: Arial, sans-serif;">
                            <li>Develop, launch, and manage 30+ websites for global clients, ensuring fast loading speeds, clean performance, and high SEO rankings.</li>
                            <li>Engineer custom WordPress themes from scratch, utilizing standard actions/filters, optimizing codebase scripts to minimize load times.</li>
                            <li>Convert design templates (Figma/Sketch) into clean, production-ready, fully responsive structures in Shopify, Squarespace, and Webflow.</li>
                            <li>Implement modern scroll-driven animations and complex UI/UX transitions using GSAP and ScrollTrigger.</li>
                            <li>Optimized developer setup processes, standardizing project dependencies and deployment mechanisms.</li>
                        </ul>
                    </div>
                </div>
            </section>

            <!-- Technical Skills -->
            <section class="mb-5">
                <h2 class="text-xs font-bold uppercase border-b border-black pb-0.5 mb-2 tracking-wide" style="font-family: Arial, sans-serif;">
                    Technical Skills & Expertise
                </h2>
                <div class="text-[11px] leading-relaxed text-gray-800 space-y-1" style="font-family: Arial, sans-serif;">
                    <div><strong>Languages & Frameworks:</strong> React.js, JavaScript (ES6+), HTML5, CSS3, Tailwind CSS, TypeScript.</div>
                    <div><strong>Platforms & CMS:</strong> WordPress (Custom Theme & Plugin Development), Shopify, Webflow, Squarespace.</div>
                    <div><strong>Libraries & Tooling:</strong> GSAP, ScrollTrigger, Git, Figma Integration, REST APIs, Vite.</div>
                    <div><strong>Performance & SEO:</strong> Core Web Vitals optimization, semantic markup audits, accessibility compliance.</div>
                </div>
            </section>

            <!-- Education -->
            <section class="mb-5">
                <h2 class="text-xs font-bold uppercase border-b border-black pb-0.5 mb-2 tracking-wide" style="font-family: Arial, sans-serif;">
                    Education
                </h2>
                <div class="space-y-3">
                    <div>
                        <div class="flex justify-between items-baseline font-bold text-[11px]" style="font-family: Arial, sans-serif;">
                            <span>MASTER OF COMPUTER APPLICATIONS (MCA)</span>
                            <span class="font-normal text-[10px]">2023 — 2025</span>
                        </div>
                        <div class="text-[10px] text-gray-700" style="font-family: Arial, sans-serif;">
                            B H Gardi College of Engineering & Technology, Rajkot &nbsp;|&nbsp; Gujarat Technological University (GTU)
                        </div>
                    </div>
                    <div>
                        <div class="flex justify-between items-baseline font-bold text-[11px]" style="font-family: Arial, sans-serif;">
                            <span>BACHELOR OF COMPUTER APPLICATIONS (BCA)</span>
                            <span class="font-normal text-[10px]">2020 — 2023</span>
                        </div>
                        <div class="text-[10px] text-gray-700" style="font-family: Arial, sans-serif;">
                            OMVVIM College, Morbi &nbsp;|&nbsp; Saurashtra University
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <style>
        /* Custom print page setups */
        @media print {
            /* Override general layouts and background structures */
            body {
                background: #ffffff !important;
                background-image: none !important;
                color: #000000 !important;
                font-family: Arial, Helvetica, sans-serif !important;
            }
            .paper-texture, .custom-cursor, nav, footer, #navbar, #mobile-menu, #preloader {
                display: none !important;
            }
            main {
                max-width: 100% !important;
                padding: 0 !important;
                margin: 0 !important;
            }
            /* Clean sections breaking on multiple pages */
            section {
                page-break-inside: avoid;
            }
        }
    </style>

    <script is:inline>
        window.addEventListener('DOMContentLoaded', () => {
            // Re-initialize Lucide Icons for dynamic content
            if (window.lucide) {
                window.lucide.createIcons();
            }

            // Bind print trigger
            const printBtn = document.getElementById('print-btn');
            if (printBtn) {
                printBtn.addEventListener('click', () => {
                    window.print();
                });
            }
        });
    </script>
</Layout>
