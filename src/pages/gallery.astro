<link rel="apple-touch-icon" href="favicon.png">
<script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "ImageGallery",
      "name": "Shivrajsinh Zala Press Kit",
      "author": {
        "@type": "Person",
        "name": "Shivrajsinh Zala"
      },
      "image": [
        "https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-frontend-developer-1.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-rajkot-web-designer-2.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-react-developer-gujarat-3.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-wordpress-expert-4.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-software-engineer-rajkot-5.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-brutalist-web-design-6.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-shopify-ecommerce-developer-7.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-digital-marketing-expert-8.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-gsap-animation-developer-9.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-webflow-designer-10.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-frontend-developer-11.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-rajkot-web-designer-12.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-react-developer-gujarat-13.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-wordpress-expert-14.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-software-engineer-rajkot-15.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-brutalist-web-design-16.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-shopify-ecommerce-developer-17.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-digital-marketing-expert-18.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-gsap-animation-developer-19.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-webflow-designer-20.jpg","https://shivrajsinh.in/assets/images/gallery/shivrajsinh-zala-frontend-developer-21.jpg","https://shivrajsinh.in/assets/images/gallery/shi