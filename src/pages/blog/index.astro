---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blog-posts';
import { pageUrl } from '../../utils/seo';

const blogIndexUrl = pageUrl('/blog');
---

<Layout
	title="Blog — Shivrajsinh Zala | Frontend Developer Rajkot"
	description="Articles on frontend development, WordPress, Shopify, Webflow, brutalist design, and hiring a developer in Rajkot, Gujarat."
>
	<Fragment slot="head">
		<meta property="og:type" content="website" />
		<meta property="og:url" content={blogIndexUrl} />
		<meta property="og:title" content="Blog — Shivrajsinh Zala" />
		<meta
			property="og:description"
			content="Articles on frontend development, WordPress, Shopify, and web design from Shivrajsinh Zala in Rajkot, Gujarat."
		/>
		<meta property="og:image" content="https://shivrajsinh.in/assets/images/og-image.png" />
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'Blog',
			name: 'Shivrajsinh Zala Blog',
			url: blogIndexUrl,
			description: 'Frontend development, WordPress, and e-commerce articles by Shivrajsinh Zala.',
			author: {
				'@type': 'Person',
				name: 'Shivrajsinh Zala',
				url: 'https://shivrajsinh.in/',
			},
			blogPost: blogPosts.map((post) => ({
				'@type': 'BlogPosting',
				headline: post.title,
				url: pageUrl(`/blog/${post.slug}`),
				datePublished: post.date,
			})),
		})} />
	</Fragment>

	<main class="relative z-10 pt-24 pb-20 px-4">
		<div class="max-w-5xl mx-auto">
			<header class="mb-12 border-4 border-black bg-brutal-yellow p-6 md:p-10 shadow-[12px_12px_0_0_#000]">
				<div class="font-mono text-xs bg-black text-white inline-block px-3 py-1 mb-4">WRITING</div>
				<h1 class="text-4xl md:text-6xl font-black tracking-tighter uppercase mb-4">Blog</h1>
				<p class="font-mono text-sm md:text-base max-w-2xl">
					Notes on frontend development, WordPress, Shopify, and design — from Rajkot, Gujarat.
				</p>
			</header>

			<ul class="space-y-4">
				{
					blogPosts.map((post) => (
						<li>
							<a
								href={`/blog/${post.slug}`}
								class="block bg-white border-4 border-black p-5 md:p-6 shadow-[6px_6px_0_0_#000] hover:shadow-[10px_10px_0_0_#FF006E] hover:-translate-y-0.5 hover:-translate-x-0.5 transition-all group"
							>
								<div class="flex flex-wrap items-center gap-3 mb-2">
									<span class="font-mono text-[10px] bg-brutal-black text-white px-2 py-1">{post.tag}</span>
									<time datetime={post.date} class="font-mono text-xs text-gray-600">
										{post.date}
									</time>
								</div>
								<h2 class="text-xl md:text-2xl font-bold group-hover:text-brutal-pink transition-colors">{post.title}</h2>
								<p class="font-mono text-sm text-gray-700 mt-2">{post.description}</p>
								<span class="inline-block mt-3 font-mono text-xs font-bold">READ →</span>
							</a>
						</li>
					))
				}
			</ul>

			<p class="mt-12 text-center font-mono text-sm">
				<a href="/" class="underline hover:text-brutal-pink">← Back to portfolio</a>
				<span class="mx-2">·</span>
				<a href="/directory" class="underline hover:text-brutal-pink">Site directory</a>
			</p>
		</div>
	</main>
</Layout>
