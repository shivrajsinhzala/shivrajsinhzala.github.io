                        <div class="tilt-inner">
                            <div class="font-mono text-[10px] md:text-xs text-black uppercase tracking-widest opacity-60 mb-2 md:mb-4">Track Record</div>
                            <div class="font-bold text-xl md:text-3xl leading-tight mb-1">30+ WEBSITES</div>
                            <div class="font-bold text-lg md:text-2xl leading-tight">BUILT</div>
