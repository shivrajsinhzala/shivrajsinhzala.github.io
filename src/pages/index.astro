        <div class="hero-bg">
            <div class="hero-parallax absolute inset-0" data-speed="30"><div class="hero-shape hero-shape-1"></div></div>
            <div class="hero-parallax absolute inset-0" data-speed="-20"><div class="hero-shape hero-shape-2"></div></div>
            <div class="hero-parallax absolute inset-0" data-speed="15"><div class="hero-shape hero-shape-3"></div></div>
