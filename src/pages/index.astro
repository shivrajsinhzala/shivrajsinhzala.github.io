                        <img src="/assets/images/shivrajsinh-zala-frontend-developer-rajkot.webp" alt="Shivrajsinh Zala — Frontend Developer from Rajkot, Gujarat" width="1024" height="1024" class="w-full h-auto block hover:scale-105 transition-transform duration-500" loading="eager" fetchpriority="high">
                    </div>

                    <div class="bg-white brutal-border brutal-shadow p-4 md:p-5 rotate-[-1deg] tilt-card" data-tilt>
                        <div class="tilt-inner">
                            <div class="flex items-center gap-2 md:gap-4 mb-2 md:mb-4">
                                <div class="font-mono text-[10px] md:text-xs text-gray-500 uppercase tracking-widest">Status</div>
