                                    d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="absolute top-0 left-0 w-full h-full opacity-5 text-[25vw] font-bold leading-none select-none pointer-events-none flex items-center justify-center font-mono"
            id="contact-bg">
            @
        </div>
    </section>



    <!-- Image Lightbox Modal -->
    <div id="image-lightbox" class="fixed inset-0 z-[9999999] hidden flex-col items-center justify-center transition-opacity duration-300 opacity-0" style="background: rgba(0, 0, 0, 0.75); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);">
        <div class="absolute top-4 right-4 flex gap-2 md:gap-4 z-50">
            <button id="lightbox-zoom-out" class="w-10 h-10 md:w-12 md:h-12 bg-brutal-black text-white brutal-border flex items-center justify-center hover:bg-brutal-yellow hover:text-black transition-colors" title="Zoom Out" aria-label="Zoom out">
                <i data-lucide="zoom-out" style="width: 1.5em; height: 1.5em;"></i>
            </button>
            <button id="lightbox-zoom-in" class="w-10 h-10 md:w-12 md:h-12 bg-brutal-black text-white brutal-border flex items-center justify-center hover:bg-brutal-yellow hover:text-black transition-colors" title="Zoom In" aria-label="Zoom in">
                <i data-lucide="zoom-in" style="width: 1.5em; height: 1.5em;"></i>
            </button>
            <button id="lightbox-close" class="w-10 h-10 md:w-12 md:h-12 bg-brutal-pink text-black brutal-border flex items-center justify-center hover:bg-black transition-colors" title="Close" aria-label="Close lightbox">
                <i data-lucide="x" style="width: 1.5em; height: 1.5em;"></i>
            </button>
        </div>
        <div class="w-full h-full p-4 md:p-16 overflow-hidden flex items-center justify-center relative" id="lightbox-container">
            <img id="lightbox-img" class="max-w-full max-h-full object-contain transition-transform duration-200 shadow-2xl" style="transform-origin: center; cursor: grab;" draggable="false" alt="Project preview">
        </div>
    </div>
    </main>

    <script is:inline>
        // @ts-nocheck
        document.addEventListener('astro:page-load', () => {
        // ===== TEXT SCRAMBLE CLASS =====
        class TextScramble {
            constructor(el) {
                this.el = el;
                this.chars = '!<>-_\\/[]{}—=+*^?#________';
                this.update = this.update.bind(this);
            }
            setText(newText) {
                const oldText = this.el.innerText;
                const length = Math.max(oldText.length, newText.length);
                const promise = new Promise((resolve) => this.resolve = resolve);
                this.queue = [];
                for (let i = 0; i < length; i++) {
                    const from = oldText[i] || '';
                    const to = newText[i] || '';
                    const start = Math.floor(Math.random() * 40);
                    const end = start + Math.floor(Math.random() * 40);
                    this.queue.push({ from, to, start, end });
                }
                cancelAnimationFrame(this.frameRequest);
                this.frame = 0;
                this.update();
                return promise;
            }
            update() {
                let output = '';
                let complete = 0;
                for (let i = 0, n = this.queue.length; i < n; i++) {
                    let { from, to, start, end, char } = this.queue[i];
                    if (this.frame >= end) {
                        complete++;
                        output += to;
                    } else if (this.frame >= start) {
                        if (!char || Math.random() < 0.28) {
                            char = this.randomChar();
                            this.queue[i].char = char;
                        }
                        output += `<span class="opacity-50">${char}</span>`;
                    } else {
                        output += from;
                    }
                }
                this.el.innerHTML = output;
                if (complete === this.queue.length) {
                    this.resolve();
                } else {
                    this.frameRequest = requestAnimationFrame(this.update);
                    this.frame++;
                }
            }
            randomChar() {
                return this.chars[Math.floor(Math.random() * this.chars.length)];
            }
        }

        // ===== ROLL-UP TEXT PREPARATION =====
        document.querySelectorAll('.hover-word').forEach(word => {
            const text = word.innerText;
            word.innerHTML = '';
            text.split('').forEach((char, i) => {
                const wrap = document.createElement('span');
                wrap.className = 'char-wrap';
                
                const inner = document.createElement('span');
                inner.className = 'char';
                inner.setAttribute('data-char', char);
                inner.style.transitionDelay = `${i * 0.03}s`;
                inner.innerText = char === ' ' ? '\u00A0' : char;
                
                wrap.appendChild(inner);
                word.appendChild(wrap);
            });
        });

        // ===== PARALLAX HERO SHAPES =====
        const heroSection = document.getElementById('about');
        if (heroSection && navigator.maxTouchPoints === 0) {
            heroSection.addEventListener('mousemove', (e) => {
                const x = (e.clientX / window.innerWidth - 0.5) * 2;
                const y = (e.clientY / window.innerHeight - 0.5) * 2;
                
                document.querySelectorAll('.hero-parallax').forEach(wrap => {
                    const speed = wrap.getAttribute('data-speed');
                    gsap.to(wrap, { x: x * speed, y: y * speed, duration: 1, ease: 'power2.out' });
                });
            });
            heroSection.addEventListener('mouseleave', () => {
                gsap.to('.hero-parallax', { x: 0, y: 0, duration: 1, ease: 'power2.out' });
            });
        }

        // Global scripts (Lenis, Cursor, GSAP ScrollTrigger) have been moved to GlobalScripts.astro

        // ===== PRELOADER =====
        const counter = document.getElementById('counter');
        const progress = document.getElementById('progress');
        const preloader = document.getElementById('preloader');
        let count = 0;

        const isLighthouse = typeof navigator !== 'undefined' && (
            navigator.userAgent.includes('Lighthouse') || 
            navigator.userAgent.includes('HeadlessChromium') || 
            navigator.webdriver
        );

        const hasTransition = sessionStorage.getItem('page-transition-type') || sessionStorage.getItem('page-transition');
        if (isLighthouse || hasTransition) {
            if (preloader) preloader.style.display = 'none';
            initAnimations();
        } else {
            const loadInterval = setInterval(() => {
                count += Math.floor(Math.random() * 12) + 4; // Snappier load for human users (~150-250ms)
                if (count >= 100) {
                    count = 100;
                    clearInterval(loadInterval);
                    setTimeout(() => {
                        gsap.to(preloader.children, { scale: 0.9, opacity: 0, duration: 0.4, ease: 'power2.in' });
                        gsap.to(preloader, {
                            yPercent: -100,
                            duration: 1.0,
                            delay: 0.2,
                            ease: 'power4.inOut',
                            onComplete: () => {
                                preloader.style.display = 'none';
                                initAnimations();
                            }
                        });
                    }, 200); // Shorter pause before sliding out
                }
                if (counter) counter.textContent = count;
                if (progress) progress.style.width = count + '%';
            }, 25);
        }

        // Prevent browser scroll restoration from breaking GSAP ScrollTrigger
        if ('scrollRestoration' in history) {
            history.scrollRestoration = 'manual';
        }
        window.scrollTo(0, 0);

        // ===== MARQUEE CLONE =====
        const mc = document.querySelector('.marquee-content');
        if (mc) {
            const clone = mc.cloneNode(true);
            mc.parentElement.appendChild(clone);
            const clone2 = mc.cloneNode(true);
            mc.parentElement.appendChild(clone2);
        }

        // ===== GSAP ANIMATIONS =====
        function setupHorizontalScroll() {
            // Re-attach scroll bottom logic and velocity skew now that global window.lenis exists
            const scrollBtn = document.getElementById('scroll-bottom-btn');
            if (scrollBtn && window.lenis) {
                scrollBtn.addEventListener('click', () => {
                    window.lenis.scrollTo('#projects', { duration: 2 });
                });
            }

            if (window.lenis) {
                let currentSkew = 0;
                window.lenis.on('scroll', ({ velocity }) => {
                    const target = Math.min(Math.max(velocity * 0.04, -3), 3);
                    currentSkew += (target - currentSkew) * 0.1;
                    gsap.set('.skew-scroll', { skewY: currentSkew });
                });
            }

            if (window.innerWidth > 768) {
                const track = document.getElementById('horizontal-track');
                const cards = track.querySelectorAll('.project-card');

                const getScrollAmount = () => {
                    return -(track.scrollWidth - window.innerWidth + 100);
                };

                const horizontalTween = gsap.to(track, {
                    x: getScrollAmount,
                    ease: 'none',
                    scrollTrigger: {
                        trigger: '.horizontal-wrapper',
                        start: 'top top',
                        end: () => `+=${track.scrollWidth - window.innerWidth + 200}`,
                        pin: true,
                        scrub: 1,
                        invalidateOnRefresh: true,
                        anticipatePin: 1,
                        onRefresh: (self) => self.animation.invalidate(),
                        onUpdate: (self) => {
                            cards.forEach((card, i) => {
                                const rect = card.getBoundingClientRect();
                                if (rect.left < window.innerWidth * 0.8 && rect.right > 0) {
                                    const img = card.querySelector('.img-reveal');
                                    if (img && !img.classList.contains('revealed')) {
                                        img.classList.add('revealed');
                                    }
                                }
                            });
                        }
                    }
                });

                cards.forEach((card) => {
                    const img = card.querySelector('.project-img') || card.querySelector('.empty-slot');
                    if (img) {
                        gsap.fromTo(img,
                            { scale: 1.2 },
                            {
                                scale: 1,
                                ease: 'none',
                                scrollTrigger: {
                                    trigger: card,
                                    containerAnimation: horizontalTween,
                                    start: 'left right',
                                    end: 'right left',
                                    scrub: true
                                }
                            }
                        );
                    }
                });
            } else {
                document.querySelectorAll('.img-reveal').forEach(img => {
                    ScrollTrigger.create({
                        trigger: img,
                        start: 'top 85%',
                        onEnter: () => img.classList.add('revealed')
                    });
                });
            }
        }

        function setupSkillAnimations() {
            gsap.utils.toArray('.skill-card').forEach((card, i) => {
                gsap.to(card, {
                    opacity: 1, y: 0, duration: 0.8, delay: i * 0.1, ease: 'power4.out',
                    scrollTrigger: { trigger: card, start: 'top 85%', toggleActions: 'play none none reverse' }
                });
            });

            gsap.utils.toArray('.skill-bar').forEach(bar => {
                gsap.to(bar, {
                    width: bar.dataset.width, duration: 1.5, ease: 'power4.out',
                    scrollTrigger: { trigger: bar, start: 'top 90%', toggleActions: 'play none none reverse' }
                });
            });
        }

        function setupExperienceAnimations() {
            gsap.utils.toArray('.exp-item').forEach((el, i) => {
                gsap.to(el, {
                    opacity: 1, y: 0, duration: 0.8, delay: i * 0.2, ease: 'power4.out',
                    scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none reverse' }
                });
            });

            gsap.utils.toArray('.stagger-item').forEach((item, i) => {
                gsap.to(item, {
                    opacity: 1, y: 0, duration: 0.5, delay: i * 0.1, ease: 'power3.out',
                    scrollTrigger: { trigger: item.parentElement, start: 'top 80%', toggleActions: 'play none none reverse' }
                });
            });

            gsap.utils.toArray('.stat-item').forEach((el, i) => {
                gsap.to(el, {
                    opacity: 1, y: 0, duration: 0.6, delay: i * 0.1, ease: 'power4.out',
                    scrollTrigger: {
                        trigger: el, start: 'top 90%', once: true,
                        onEnter: () => {
                            if (i === 0) {
                                let obj = { val: 0 };
                                gsap.to(obj, {
                                    val: 30, duration: 2, ease: 'power4.out',
                                    onUpdate: () => document.getElementById('stat-websites').textContent = Math.floor(obj.val) + '+'
                                });
                            }
                        }
                    }
                });
            });
        }

        function setupParallax() {
            gsap.utils.toArray('.reveal-label').forEach(el => {
                gsap.to(el, { opacity: 1, y: 0, duration: 0.6, scrollTrigger: { trigger: el, start: 'top 90%' } });
            });
            gsap.utils.toArray('.reveal-heading').forEach(el => {
                gsap.fromTo(el, { y: 50, opacity: 0 }, { y: 0, opacity: 1, duration: 1, ease: 'power4.out', scrollTrigger: { trigger: el, start: 'top 85%' } });
            });
            gsap.utils.toArray('.reveal-text').forEach(el => {
                gsap.to(el, { opacity: 1, y: 0, duration: 0.8, scrollTrigger: { trigger: el, start: 'top 90%' } });
            });
            gsap.utils.toArray('.reveal-tags').forEach(el => {
                gsap.to(el, { opacity: 1, y: 0, duration: 0.8, stagger: 0.1, scrollTrigger: { trigger: el, start: 'top 90%' } });
            });
            gsap.utils.toArray('.reveal-card').forEach(el => {
                gsap.to(el, { opacity: 1, y: 0, duration: 1, ease: 'power4.out', scrollTrigger: { trigger: el, start: 'top 85%' } });
            });
            gsap.utils.toArray('.edu-item').forEach((item, i) => {
                gsap.to(item, { opacity: 1, x: 0, duration: 0.8, delay: i * 0.15, ease: 'power4.out', scrollTrigger: { trigger: item, start: 'top 85%', toggleActions: 'play none none reverse' } });
            });
            gsap.to('#ai-bg-text', { x: 200, scrollTrigger: { trigger: '#ai-heading', start: 'top bottom', end: 'bottom top', scrub: 1 } });
            gsap.to('#contact-bg', { x: -100, scrollTrigger: { trigger: '#contact', start: 'top bottom', end: 'bottom top', scrub: 1 } });
        }

        function initAnimations() {
            gsap.to('#navbar', { y: 0, duration: 0.8, ease: 'power4.out', delay: 0.2 });

            gsap.to('.line-inner', {
                y: 0,
                rotateX: 0,
                opacity: 1,
                duration: 1.2,
                stagger: 0.1,
                ease: 'power4.out',
                delay: 0.4
            });

            gsap.to('.reveal-badge', { opacity: 1, y: 0, duration: 0.8, delay: 0.6, ease: 'power4.out' });
            gsap.to('.reveal-card', { opacity: 1, y: 0, duration: 1, delay: 0.8, ease: 'power4.out' });
            gsap.to('.reveal-buttons', { opacity: 1, y: 0, duration: 1, delay: 1, ease: 'power4.out' });
            gsap.to('.reveal-cards', { opacity: 1, y: 0, duration: 1, stagger: 0.1, delay: 1.2, ease: 'power4.out' });

            document.querySelectorAll('[data-scramble]').forEach(el => {
                if (el.closest('#preloader')) return;
                const fx = new TextScramble(el);
                const original = el.innerText;
                el.addEventListener('mouseenter', () => fx.setText(original));
            });

            setupHorizontalScroll();
            setupSkillAnimations();
            setupExperienceAnimations();
            setupParallax();
            ScrollTrigger.refresh();
        }

        // ===== 3D TILT CARDS =====
        if (navigator.maxTouchPoints === 0) {
            document.querySelectorAll('[data-tilt]').forEach(card => {
                card.addEventListener('mousemove', (e) => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    const centerX = rect.width / 2;
                    const centerY = rect.height / 2;
                    const rotateX = (y - centerY) / -12; // Inverted for natural tilt
                    const rotateY = (x - centerX) / 12;
                    
                    gsap.to(card, {
                        rotateX: rotateX,
                        rotateY: rotateY,
                        x: -4,
                        y: -4,
                        scale: 1.02,
                        duration: 0.1,
                        transformPerspective: 1000,
                        ease: 'power1.out',
                        overwrite: 'auto'
                    });
                });
                card.addEventListener('mouseleave', () => {
                    gsap.to(card, {
                        rotateX: 0,
                        rotateY: 0,
                        x: 0,
                        y: 0,
                        scale: 1,
                        duration: 0.5,
                        ease: 'power3.out',
                        overwrite: 'auto'
                    });
                });
            });
        }



        // ===== SCROLL TO SECTIONS =====
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target && window.lenis) window.lenis.scrollTo(target, { offset: 0, duration: 2 });
            });
        });

        // ===== GLITCH EFFECT =====
        const glitchTitle = document.getElementById('hero-title');
        let glitchInterval = null;
        const glitchObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    if (!glitchInterval) {
                        glitchInterval = setInterval(() => {
                            glitchTitle.style.textShadow = `${Math.random() * 4 - 2}px 0 #FF006E, ${Math.random() * 4 - 2}px 0 #00F5FF`;
                            setTimeout(() => { glitchTitle.style.textShadow = 'none'; }, 100);
                        }, 5000);
                    }
                } else {
                    clearInterval(glitchInterval);
                    glitchInterval = null;
                }
            });
        }, { threshold: 0 });
        glitchObserver.observe(glitchTitle);

        // Refresh ScrollTrigger on resize and full load
        let resizeTimer;
        window.addEventListener('resize', () => {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(() => {
                ScrollTrigger.refresh();
            }, 250);
        });
        window.addEventListener('load', () => {
            ScrollTrigger.refresh();
        });



        // ===== DIRECTION-AWARE CONTACT CARD HOVER =====
        // Hide all fills off-screen initially
        gsap.set('.contact-item-fill', { x: '-101%', y: '0%' });

        document.querySelectorAll('.dir-reveal-card').forEach(card => {
            const fill = card.querySelector('.contact-item-fill');
            if (!fill) return;

            function getDir(e) {
                const r = card.getBoundingClientRect();
                const x = e.clientX - r.left - r.width / 2;
                const y = e.clientY - r.top - r.height / 2;
                if (Math.abs(x) >= Math.abs(y)) {
                    return x > 0 ? { x: '101%', y: '0%' } : { x: '-101%', y: '0%' };
                } else {
                    return y > 0 ? { x: '0%', y: '101%' } : { x: '0%', y: '-101%' };
                }
            }

            card.addEventListener('mouseenter', e => {
                const dir = getDir(e);
                gsap.set(fill, { x: dir.x, y: dir.y });
                gsap.to(fill, { x: '0%', y: '0%', duration: 0.45, ease: 'power3.out' });
            });

            card.addEventListener('mouseleave', e => {
                const dir = getDir(e);
                gsap.to(fill, { x: dir.x, y: dir.y, duration: 0.4, ease: 'power3.in' });
            });

            // Lift card on hover
            card.addEventListener('mouseenter', () => {
                gsap.to(card, { y: -4, x: -4, boxShadow: '8px 8px 0px 0px #000', duration: 0.25, ease: 'power2.out' });
            });
            card.addEventListener('mouseleave', () => {
                gsap.to(card, { y: 0, x: 0, boxShadow: 'none', duration: 0.3, ease: 'power2.inOut' });
            });
        });

        // ===== IMAGE LIGHTBOX =====
        const lightbox = document.getElementById('image-lightbox');
        const lightboxImg = document.getElementById('lightbox-img');
        const lightboxClose = document.getElementById('lightbox-close');
        const lightboxZoomIn = document.getElementById('lightbox-zoom-in');
        const lightboxZoomOut = document.getElementById('lightbox-zoom-out');
        const lightboxContainer = document.getElementById('lightbox-container');
        
        let zoomLevel = 1;
        let isDragging = false;
        let startX, startY, currentX = 0, currentY = 0;

        const updateTransform = () => {
            lightboxImg.style.transform = `translate(${currentX}px, ${currentY}px) scale(${zoomLevel})`;
            if(zoomLevel > 1) {
                lightboxImg.style.cursor = isDragging ? 'grabbing' : 'grab';
            } else {
                lightboxImg.style.cursor = 'default';
            }
        };

        // Make project cards clickable to open lightbox
        document.querySelectorAll('.project-card[data-cursor="view"]').forEach(card => {
            card.style.cursor = 'pointer'; // Fallback
            card.addEventListener('click', (e) => {
                // Ignore if clicked on the REPO button
                if(e.target.closest('a') || e.target.tagName.toLowerCase() === 'a') return;

                const img = card.querySelector('.project-img');
                if(!img) return; // ignore empty slots
                
                lightboxImg.src = img.src;
                zoomLevel = 1;
                currentX = 0;
                currentY = 0;
                updateTransform();
                
                lightbox.classList.remove('hidden');
                lightbox.classList.add('flex');
                // Trigger reflow
                void lightbox.offsetWidth;
                lightbox.classList.remove('opacity-0');
                document.body.style.overflow = 'hidden';
            });
        });

        const closeLightbox = () => {
            lightbox.classList.add('opacity-0');
            setTimeout(() => {
                lightbox.classList.add('hidden');
                lightbox.classList.remove('flex');
                document.body.style.overflow = '';
            }, 300);
        };

        lightboxClose.addEventListener('click', closeLightbox);
        
        lightboxZoomIn.addEventListener('click', () => {
            zoomLevel = Math.min(zoomLevel + 0.5, 4);
            updateTransform();
        });
        
        lightboxZoomOut.addEventListener('click', () => {
            zoomLevel = Math.max(zoomLevel - 0.5, 1);
            if(zoomLevel === 1) {
                currentX = 0; currentY = 0;
            }
            updateTransform();
        });

        // Panning Logic (Mouse)
        lightboxContainer.addEventListener('mousedown', (e) => {
            if (zoomLevel <= 1 || e.target !== lightboxImg) {
                if (e.target === lightboxContainer) closeLightbox();
                return;
            }
            isDragging = true;
            startX = e.clientX - currentX;
            startY = e.clientY - currentY;
            updateTransform();
        });

        window.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            currentX = e.clientX - startX;
            currentY = e.clientY - startY;
            updateTransform();
        });

        window.addEventListener('mouseup', () => {
            if (isDragging) {
                isDragging = false;
                updateTransform();
            }
        });

        // Panning Logic (Touch)
        lightboxContainer.addEventListener('touchstart', (e) => {
            if (zoomLevel <= 1 || e.target !== lightboxImg) return;
            isDragging = true;
            startX = e.touches[0].clientX - currentX;
            startY = e.touches[0].clientY - currentY;
            updateTransform();
        }, {passive: true});

        window.addEventListener('touchmove', (e) => {
            if (!isDragging) return;
            e.preventDefault(); // prevent scrolling
            currentX = e.touches[0].clientX - startX;
            currentY = e.touches[0].clientY - startY;
            updateTransform();
        }, {passive: false});

        window.addEventListener('touchend', () => {
            if (isDragging) {
                isDragging = false;
                updateTransform();
            }
        });

        // Close on escape key
        window.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) {
                closeLightbox();
            }
        });

        // Initialize Lucide Icons
        if (window.lucide) {
            window.lucide.createIcons();
        }


