<meta name="author" content="Shivrajsinh Zala">
<meta name="theme-color" content="#FFE900">
<meta property="og:type" content="website">
<meta property="og:url" content="https://shivrajsinh.in/">
<meta property="og:title" content="Shivrajsinh Zala — Frontend Developer">
