        </div>
        <div class="font-mono text-gray-500 text-xs mt-8 max-w-md text-center px-4 scramble-text" data-scramble>
            LOADING GSAP • SCROLLTRIGGER • LENIS • GRAPH PAPER • SARCASM
        </div>
    </div>
    <noscript><style>.preloader{display:none!important}</style></noscript>

    <main id="main-content">
    <!-- Hero Section -->
