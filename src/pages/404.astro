---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 — Page Not Found | Shivrajsinh Zala</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700;800&display=swap" rel="stylesheet">
</head>
<body class="font-mono min-h-screen flex items-center justify-center text-brutal-black relative" style="background-color: #f8f7f4;">
    <!-- Graph paper background -->
    <div class="fixed inset-0 pointer-events-none" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(0,0,0,0.04) 39px, rgba(0,0,0,0.04) 40px), repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(0,0,0,0.04) 39px, rgba(0,0,0,0.04) 40px);"></div>
    
    <div class="text-center p-8 relative z-10">
        <div class="text-[clamp(6rem,20vw,15rem)] font-extrabold leading-none text-brutal-pink drop-shadow-[6px_6px_0_rgba(0,0,0,1)]">404</div>
        <p class="text-[clamp(1rem,3vw,1.5rem)] my-6 text-gray-800">This page doesn't exist.<br>But I do. Let's go back.</p>
        <a href="/" class="inline-block px-8 py-4 bg-brutal-black text-white no-underline border-[3px] border-black font-bold text-base shadow-[6px_6px_0_0_var(--color-brutal-yellow)] hover:-translate-y-1 hover:-translate-x-1 hover:shadow-[10px_10px_0_0_var(--color-brutal-pink)] transition-all duration-200">
            &larr; BACK TO PORTFOLIO
        </a>
        <p class="mt-8 text-xs text-gray-500">SZ://DEV — shivrajsinh.in</p>
    </div>
</body>
</html>
