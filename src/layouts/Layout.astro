---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import GlobalScripts from '../components/GlobalScripts.astro';
import GitHubPagesRedirect from '../components/GitHubPagesRedirect.astro';
import { pageUrl } from '../utils/seo';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description?: string;
	robots?: string;
}

const { title, description = "Portfolio of Shivrajsinh Zala", robots = "index, follow" } = Astro.props;
const canonicalURL = pageUrl(Astro.url.pathname);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<GitHubPagesRedirect />
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="robots" content={robots} />
		<meta name="theme-color" content="#FFE900" />
		<meta name="author" content="Shivrajsinh Zala" />
		<link rel="icon" type="image/png" sizes="48x48" href="/favicon.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/assets/images/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.json" />
		<meta property="og:site_name" content="Shivrajsinh Zala | Portfolio" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="canonical" href={canonicalURL} />

		<!-- Preconnect to Third-Party Origins -->
		<link rel="preconnect" href="https://scripts.clarity.ms" />
		<link rel="preconnect" href="https://static.cloudflareinsights.com" />

		<!-- Critical Web Fonts Preload -->
		<link rel="preload" href="/assets/fonts/bebas-neue-400.ttf" as="font" type="font/ttf" crossorigin />
		<link rel="preload" href="/assets/fonts/space-grotesk-700.ttf" as="font" type="font/ttf" crossorigin />
		<link rel="preload" href="/assets/fonts/jetbrains-mono-700.ttf" as="font" type="font/ttf" crossorigin />

		<!-- Global Analytics (Deferred to window load to unblock main thread & initial rendering metrics) -->
		<script is:inline>
			window.addEventListener('load', () => {
				// Google Analytics (gtag.js)
				const gaScript = document.createElement('script');
				gaScript.src = 'https://www.googletagmanager.com/gtag/js?id=G-170NQJN07E';
				gaScript.async = true;
				document.head.appendChild(gaScript);

				window.dataLayer = window.dataLayer || [];
				window.gtag = function(){dataLayer.push(arguments);}
				gtag('js', new Date());
				gtag('config', 'G-170NQJN07E');

				// Microsoft Clarity
				(function(c,l,a,r,i,t,y){
					c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
					t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
					y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
				})(window, document, "clarity", "script", "wwamkblght");
			});
		</script>
		<slot name="head" />
		<ClientRouter />
        <script is:inline>
          if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
          window.scrollTo(0, 0);
          
          // Immediate check for active page transition to prevent flashing
          const transitionType = sessionStorage.getItem('page-transition-type') || sessionStorage.getItem('page-transition');
          if (transitionType) {
              document.documentElement.classList.add('transitioning');
          }
        </script>
        <style>
          html.transitioning main,
          html.transitioning nav {
              opacity: 0 !important;
          }
        </style>
	</head>
	<body class="font-sans">
        <div class="paper-texture"></div>
        
        <!-- Custom Cursor -->
        <div class="custom-cursor" transition:persist>
            <svg class="cursor-icon" width="30" height="34" viewBox="0 0 30 34" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 3L12 30L16 19L27 15L3 3Z" fill="#e00062" stroke="black" stroke-width="3" stroke-linejoin="round" stroke-linecap="round"/>
            </svg>
            <div class="cursor-text">VIEW</div>
        </div>

		<Navbar />
		<slot />
		<Footer />

        <!-- Global Scripts -->
        <script is:inline src="/assets/vendor/gsap.min.js" defer></script>
        <script is:inline src="/assets/vendor/ScrollTrigger.min.js" defer></script>
        <script is:inline src="/assets/vendor/lenis.min.js" defer></script>
        <script is:inline src="/assets/vendor/lucide.min.js" defer></script>
        
        <GlobalScripts />
	</body>
</html>
