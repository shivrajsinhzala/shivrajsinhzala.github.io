<!-- Footer -->
<footer class="bg-brutal-black text-white py-10 md:py-16 px-4 brutal-border border-b-0 border-x-0 relative z-10">
    <div class="max-w-6xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6 md:gap-6">
            <div class="font-mono text-xs md:text-sm text-center md:text-left">
                © 2026 SHIVRAJSINH ZALA.
            </div>
            <!-- Crawlable social links for SEO -->
            <div class="flex flex-wrap justify-center gap-3 font-mono text-[10px] md:text-xs">
                <a href="https://www.linkedin.com/in/shivrajsinh-zala/" target="_blank" rel="me noopener noreferrer" class="border border-white px-2 md:px-3 py-1 hover:border-brutal-cyan hover:text-brutal-cyan transition-colors">LINKEDIN</a>
                <a href="https://www.instagram.com/shivrajsinh.sh" target="_blank" rel="me noopener noreferrer" class="border border-white px-2 md:px-3 py-1 hover:border-brutal-pink hover:text-brutal-pink transition-colors">INSTAGRAM</a>
                <a href="https://github.com/shivrajsinhzala" target="_blank" rel="me noopener noreferrer" class="border border-white px-2 md:px-3 py-1 hover:border-[#00FF88] hover:text-[#00FF88] transition-colors">GITHUB</a>
                <span class="border border-white px-2 md:px-3 py-1">RAJKOT</span>
                <span class="border border-brutal-pink text-brutal-pink px-2 md:px-3 py-1">AVAILABLE</span>
            </div>
        </div>

        <!-- Visitor Counter -->
        <div class="flex justify-center mt-4">
            <div class="font-mono text-[10px] text-gray-500 flex items-center gap-2">
                <span class="w-1.5 h-1.5 bg-brutal-pink rounded-full animate-pulse"></span>
                <span id="visitor-count">VISITOR #—</span>
            </div>
        </div>
        <div class="flex justify-center mt-8 md:mt-10">
            <button id="terminal-btn"
                class="group brutal-border bg-brutal-black text-white px-6 py-3 md:px-8 md:py-4 font-mono text-sm md:text-base font-bold tracking-wider hover:bg-[#00FF88] hover:text-black transition-all duration-300 magnetic-btn flex items-center gap-3"
                data-magnetic>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-colors">
                    <polyline points="4 17 10 11 4 5"></polyline>
                    <line x1="12" y1="19" x2="20" y2="19"></line>
                </svg>
                <span>OPEN TERMINAL</span>
                <span class="text-[10px] opacity-50 group-hover:opacity-100 transition-opacity border border-current px-2 py-0.5">SZ://DEV</span>
            </button>
        </div>
    </div>
</footer>

<!-- Page Transition Overlay -->
<div class="page-transition-overlay" id="page-transition" style="position:fixed;inset:0;z-index:999999;display:flex;flex-direction:column;pointer-events:none;">
    <div class="transition-bar" style="flex:1;background:#00FF88;transform:scaleX(0);transform-origin:left;"></div>
    <div class="transition-bar" style="flex:1;background:#00FF88;transform:scaleX(0);transform-origin:left;"></div>
    <div class="transition-bar" style="flex:1;background:#00FF88;transform:scaleX(0);transform-origin:left;"></div>
    <div class="transition-bar" style="flex:1;background:#00FF88;transform:scaleX(0);transform-origin:left;"></div>
    <div class="transition-bar" style="flex:1;background:#00FF88;transform:scaleX(0);transform-origin:left;"></div>
    <div class="transition-bar" style="flex:1;background:#00FF88;transform:scaleX(0);transform-origin:left;"></div>
    <div class="transition-bar" style="flex:1;background:#00FF88;transform:scaleX(0);transform-origin:left;"></div>
    <div class="transition-bar" style="flex:1;background:#00FF88;transform:scaleX(0);transform-origin:left;"></div>
</div>

<script is:inline>
window.addEventListener('DOMContentLoaded', () => {
    // ===== VISITOR COUNTER =====
    const visitorEl = document.getElementById('visitor-count');
    if (visitorEl) {
        fetch('https://api.counterapi.dev/v1/shivrajsinhzala-portfolio/visits/up')
            .then(r => r.json())
            .then(data => {
                if (data.count) {
                    visitorEl.textContent = 'VISITOR #' + data.count.toLocaleString();
                }
            })
            .catch(() => { /* Silently fail — not critical */ });
    }

    // ===== TERMINAL BUTTON + PAGE TRANSITIONS =====
    const terminalBtns = document.querySelectorAll('#terminal-btn, #header-terminal-btn, #mobile-terminal-btn');
    const pageTransition = document.getElementById('page-transition');
    const transitionBars = pageTransition ? pageTransition.querySelectorAll('.transition-bar') : [];

    if (terminalBtns.length > 0 && transitionBars.length > 0 && typeof gsap !== 'undefined') {
        terminalBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                pageTransition.style.pointerEvents = 'all';
                gsap.to(transitionBars, {
                    scaleX: 1,
                    duration: 0.5,
                    stagger: 0.05,
                    ease: 'power4.inOut',
                    onComplete: () => {
                        sessionStorage.setItem('page-transition', 'entering');
                        window.location.href = '/terminal.html';
                    }
                });
            });
        });
    }

    // Entrance animation (when returning from terminal)
    (function checkEntrance() {
        const fromTransition = sessionStorage.getItem('page-transition');
        if (fromTransition === 'entering' && transitionBars.length > 0 && typeof gsap !== 'undefined') {
            sessionStorage.removeItem('page-transition');
            gsap.set(transitionBars, { scaleX: 1 });
            requestAnimationFrame(() => {
                gsap.to(transitionBars, {
                    scaleX: 0,
                    duration: 0.5,
                    stagger: 0.05,
                    ease: 'power4.inOut',
                    delay: 0.3,
                    onStart: () => {
                        transitionBars.forEach(bar => {
                            bar.style.transformOrigin = 'right';
                        });
                    },
                    onComplete: () => {
                        pageTransition.style.pointerEvents = 'none';
                        transitionBars.forEach(bar => {
                            bar.style.transformOrigin = 'left';
                        });
                    }
                });
            });
        }
    })();
});
</script>
